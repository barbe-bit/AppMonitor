@page "/_Host"
@using Microsoft.AspNetCore.Components.Web
@namespace JavaMonitor.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>应用监控中心</title>
    <base href="/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/open-iconic/1.1.1/font/css/open-iconic-bootstrap.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: 0.5px; }
        .status-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 5px; }
        .status-online { background-color: #198754; }
        .status-offline { background-color: #dc3545; animation: blink 1s infinite; }
        @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
        .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        .card-header { background: #fff; border-bottom: 1px solid #eee; font-weight: 600; }
        #blazor-error-ui { background: #fee2e2; color: #991b1b; padding: 10px 16px; position: fixed; bottom: 0; width: 100%; display: none; z-index: 9999; }
        #blazor-error-ui .dismiss { cursor: pointer; float: right; font-weight: bold; }
    </style>
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        发生了未处理的错误，请
        <a href="" class="reload">刷新页面</a> 或
        <span class="dismiss" onclick="document.getElementById('blazor-error-ui').style.display='none'">✕</span>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="_framework/blazor.server.js"></script>
</body>
</html>
